rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sos_alerts/{alertId} {
      // For production, you should restrict this to authenticated users
      // For now, allowing read/write if the request is valid
      allow read: if true; 
      allow write: if request.resource.data.vesselId != null && 
                     request.resource.data.status == "ACTIVE";
    }
  }
}
